    <style>
      .user-mention[href$="/adamforrester"] {
        color: var(--color-user-mention-fg);
        background-color: var(--bgColor-attention-muted, var(--color-attention-subtle));
        border-radius: 2px;
        margin-left: -2px;
        margin-right: -2px;
      }
      .user-mention[href$="/adamforrester"]:before,
      .user-mention[href$="/adamforrester"]:after {
        content: '';
        display: inline-block;
        width: 2px;
      }
    </style>


